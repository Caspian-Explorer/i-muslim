# =============================================================================
# i-muslim — environment variables
# =============================================================================
# Copy this file to `.env.local` and fill in the values.
# Do NOT commit `.env.local`. It's in .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# Firebase (required for /admin)
# -----------------------------------------------------------------------------
# The admin dashboard uses Firebase Auth (Google sign-in, session cookies) plus
# Firestore (named database "main") via the Firebase Admin SDK on the server.
#
# Without these, /admin shows a clear "Firebase not configured" message and
# falls back to sample data, but sign-in will not work.


# --- Client SDK (browser) ----------------------------------------------------
# Get these from:
#   Firebase Console → your project → Project Settings → General →
#     Your apps → Web app → Config (the `firebaseConfig` object)
# Only these three fields are needed for Auth + Firestore in this app.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=


# --- Admin SDK (server, service account) -------------------------------------
# Get these from:
#   Firebase Console → Project Settings → Service accounts → Generate new
#     private key → download JSON → copy values from the file.
#
# FIREBASE_PRIVATE_KEY is a multi-line PEM block. Paste it on ONE line with
# literal \n separators, wrapped in double quotes. Example:
#   FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADAN...\n-----END PRIVATE KEY-----\n"

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=


# --- Firestore named database ------------------------------------------------
# Your Firestore database ID. Default is the literal string "(default)".
# This project uses a named database called "main". If you renamed it or
# are using the default, update this value.

FIREBASE_DATABASE_ID=main


# =============================================================================
# After editing, restart `npm run dev`. Env vars are read at startup.
# =============================================================================

# Admin allowlist lives in code (lib/auth/allowlist.ts) — currently limited to
# fuad.jalilov@gmail.com. Edit that file to add more admins.
