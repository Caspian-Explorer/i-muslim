rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    match /businesses/{businessId}/{filename} {
      allow read: if true;
      allow write: if false;
    }

    match /certificationBodies/{bodyId}/{filename} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
